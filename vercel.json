{
    "version": 2,
    "framework": null,
    "outputDirectory": ".",
    "functions": {
        "api/server.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|img|favicon.ico|storage)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/server.php"
        }
    ]
}
